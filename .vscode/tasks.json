{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compilar Projeto ATR",
            "command": "cl.exe",
            "args": [
                "/EHsc",
                "/Zi",
                "/Fe:", "meu_programa.exe",
                "/I", "${workspaceFolder}/include",
                "${workspaceFolder}/src/main.cpp",
                "${workspaceFolder}/src/core/buffer.cpp",
                "${workspaceFolder}/src/rota/planejamento_rota.cpp"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compilador do Visual Studio 2022"
        }
    ]
}